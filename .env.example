# Supabase server-only data layer
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="server-only-service-role-key"

# Supabase Auth client/server cookie layer
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="publishable-or-anon-key"

# Public site URL for robots, sitemap and Open Graph URLs
NEXT_PUBLIC_SITE_URL="https://gotmeds.example"

# Public map provider key
NEXT_PUBLIC_YANDEX_MAPS_API_KEY="yandex-maps-api-key"

# Optional local SQL checks only
DATABASE_URL="postgresql://user:password@host:5432/postgres"
