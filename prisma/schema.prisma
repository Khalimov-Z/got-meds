// ==============================================
// GotMeds — Схема базы данных (Prisma ORM)
// ==============================================
// Источник: spec/features/data-architecture/data-architecture.md
// Этап 1: Таблицы Products, Pharmacies, Product_Aliases, Inventory + Cities (зависимость)
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- 1. Города (Cities) ---
// Базовая таблица для мультигородского масштабирования.
// Добавлена как зависимость для Pharmacies (FK city_id).
model City {
  id                 String     @id @default(uuid()) @db.Uuid
  name               String     // Название города (например, "Гудермес")
  centerLatitude     Float      @map("center_latitude")  // Широта центра города
  centerLongitude    Float      @map("center_longitude") // Долгота центра города
  isActive           Boolean    @default(true) @map("is_active") // Открыт ли город для поиска

  // Связи
  pharmacies Pharmacy[]

  @@map("cities")
}

// --- 2. Аптеки (Pharmacies) ---
model Pharmacy {
  id            String         @id @default(uuid()) @db.Uuid
  cityId        String         @map("city_id") @db.Uuid
  name          String         // Название аптеки
  address       String         // Адрес
  latitude      Float          // Координаты — широта
  longitude     Float          // Координаты — долгота
  tier          PharmacyTier   // Тип: киоск (TIER_1), крупная частная (TIER_2), сетевая (TIER_3)
  status        PharmacyStatus @default(ACTIVE) // Статус работы аптеки
  phone         String?        // Телефон
  whatsapp      String?        // WhatsApp
  workingHours  Json?          @map("working_hours") // JSONB — график по дням недели
  is247         Boolean        @default(false) @map("is_24_7") // Флаг для ночного фильтра

  // Связи
  city      City        @relation(fields: [cityId], references: [id])
  inventory Inventory[]

  @@map("pharmacies")
}

// --- 3. Справочник товаров (Products) ---
// Эталонная база: лекарства, медтехника, БАДы.
model Product {
  id               String          @id @default(uuid()) @db.Uuid
  name             String          // Полное правильное название
  category         ProductCategory // Категория товара
  activeIngredient String?         @map("active_ingredient") // Действующее вещество (только для medicine)
  form             String?         // Форма выпуска (таблетки, сироп, ампулы)
  dosage           String?         // Дозировка (например, "500мг", "100мл")
  isPrescription   Boolean?        @map("is_prescription") // Рецептурный ли препарат
  isSocialRisk     Boolean         @default(false) @map("is_social_risk") // Флаг "Чёрного списка"
  priceEstimate    Float?          @map("price_estimate") // Примерная цена
  description      String?         // Краткое описание (для SEO-страницы)
  imageUrl         String?         @map("image_url") // Ссылка на фото упаковки

  // Связи
  inventory Inventory[]
  aliases   ProductAlias[]

  @@map("products")
}

// --- 4. Наличие (Inventory) ---
// Связующая таблица (Many-to-Many) между аптеками и товарами.
// Используется ТОЛЬКО для Tier 2 и Tier 3 аптек.
model Inventory {
  pharmacyId String          @map("pharmacy_id") @db.Uuid
  productId  String          @map("product_id") @db.Uuid
  status     InventoryStatus // Статус наличия
  updatedAt  DateTime        @default(now()) @updatedAt @map("updated_at")
  price      Float?          // Точная цена (если сеть отдаёт)

  // Связи
  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  // Составной первичный ключ (аптека + товар)
  @@id([pharmacyId, productId])
  @@map("inventory")
}

// --- 5. Алиасы маппинга (Product_Aliases) ---
// Словарь синонимов и сокращений из 1С.
model ProductAlias {
  id             String  @id @default(uuid()) @db.Uuid
  originalString String  @map("original_string") // Исходное название из 1С (например, "Нуроф таб")
  productId      String? @map("product_id") @db.Uuid // Ссылка на эталонный товар (Nullable)
  isIgnored      Boolean @default(false) @map("is_ignored") // Игнорировать при маппинге

  // Связи
  product Product? @relation(fields: [productId], references: [id])

  @@map("product_aliases")
}

// ==============================================
// Перечисления (Enums)
// ==============================================

// Тип аптеки (Tier)
enum PharmacyTier {
  TIER_1 // Киоск
  TIER_2 // Крупная частная
  TIER_3 // Сетевая
}

// Статус работы аптеки
enum PharmacyStatus {
  ACTIVE // Работает
  PAUSED // Временно закрыта (ремонт и т.д.)
  CLOSED // Закрыта навсегда
}

// Категория товара
enum ProductCategory {
  MEDICINE       // Лекарство
  EQUIPMENT      // Медтехника
  VITAMINS       // БАДы / Витамины
  MOTHER_AND_BABY // Мать и дитя
}

// Статус наличия товара
enum InventoryStatus {
  IN_STOCK        // В наличии
  LIKELY_IN_STOCK // Вероятно в наличии
}
